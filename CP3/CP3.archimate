  <folder name="Motivation" id="id-064842cd784043368db78ede0a767736" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="CLYVO" id="id-c2caf7c10344449d9861d928bc7fa994"/>
    <element xsi:type="archimate:Driver" name="resolver um problema crítico da continuidade do cuidado do pet e da relação entre responsável, clínica e ecossistema veterinário" id="id-f22e6086c98a4af2bc01a1f5e1c67b27"/>
    <element xsi:type="archimate:Assessment" name="O índice da continuidade/persistência de recorrencia às clínicas" id="id-9e4e199e12b2435eb1b9ecae45743ab9"/>
    <element xsi:type="archimate:Assessment" name="Índice da melhora de relacionamento entre tutores e clínicas/veterinários" id="id-a5a8d14e21ef461f9b7a9df64545fbe3"/>
    <element xsi:type="archimate:Goal" name="Aumentar a recorrencia/persistência na clínica para cuidar e acompanhar a saúde dos pets dos tutores" id="id-e0938d568bfe41c2a7a74c75552d90d9"/>
    <element xsi:type="archimate:Principle" name="todos os veterinarios e tutores tenham uma relação bem estabelecida e recorrente" id="id-e3cccb3946a54d7283a8ef9bb6bdb9f5"/>
    <element xsi:type="archimate:Requirement" name="Estabelecer um chat de conversa com o tutor pelo app" id="id-a877cc0b51be4fb1bed8d14b9eb388b9"/>
    <element xsi:type="archimate:Requirement" name="Notificações para manter a recorrencia do tutor em diverços cenários." id="id-16e29d2d98574bd3af6068ca0d35276c"/>
    <element xsi:type="archimate:Assessment" name="IA conversacional com o veterinario para ajuda-lo" id="id-8d72b5afa6fd4e80b03bf4e82dee261f"/>
    <element xsi:type="archimate:Requirement" name="Histórico e informações dos pets dos tutores. disponíveis para os tutores e veterinários" id="id-c0af3eee75c647719d41701875fd80aa"/>
    <element xsi:type="archimate:Constraint" name="conexão com a API do whatsApp para conversa dinamica dentro do app" id="id-b1335cf3fdff41b3bd699c67e047a07f"/>
    <element xsi:type="archimate:Constraint" name="Obter numero dos usuarios" id="id-1784ae6cc9de42a994c008f9424f9bc4"/>
    <element xsi:type="archimate:Constraint" name="Micro serviço de notificações" id="id-452148dc555740c0ba0debf044188d46"/>
    <element xsi:type="archimate:Constraint" name="Ter uma API de algum modelo de IA para uso. e conectar com esta API" id="id-3b3c463e33114ff1bf6132927f001244"/>
    <element xsi:type="archimate:Constraint" name="IA conversacional com o veterinario para ajuda-lo" id="id-33a485b888784a4bb84c5baef4773f18"/>
    <element xsi:type="archimate:Requirement" name="IA conversacional com o veterinario para ajuda-lo" id="id-6b62ea11180249eebafb4a4b8308be1b"/>
    <element xsi:type="archimate:Constraint" name="Ter a possibilidade de ler editar e operar esse histórico e essas infos" id="id-3476c74489ce4563860d394efff79186"/>
  </folder>
